buf<i32> itoa(i32 integer)
{
    if (integer == 0) {
        buf<i32> zero = alloc_i32(1);
        zero[0] = '0';
        return zero;
    }

    i32 temp = integer;
    i32 digits = 0;

    while (temp != 0) {
        temp = temp / 10;
        digits = digits + 1;    
    }

    buf<i32> x = alloc_i32(digits);

    for (i32 i = digits - 1; i >= 0; i = i - 1) {
        x[i] = (integer % 10) + '0';
        integer = integer / 10;
    }
    
    return x;
}